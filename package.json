{
  "name": "konode",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:ui && npm run build:sw",
    "build:ui": "vite build",
    "build:sw": "vite build --config vite.sw.config.ts",
    "build:firefox": "npm run build:firefox:ui && npm run build:firefox:sw && node scripts/make-firefox-manifest.mjs dist-firefox/manifest.json",
    "build:firefox:ui": "vite build --outDir dist-firefox",
    "build:firefox:sw": "vite build --config vite.sw.config.ts --outDir dist-firefox",
    "dev": "vite build --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "check": "npm run type-check && npm run lint && npm run test"
  },
  "dependencies": {
    "lucide-react": "^0.400.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/chrome": "^0.0.268",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.19.0",
    "vite": "^5.3.4",
    "vitest": "^2.1.9"
  }
}
